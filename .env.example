# Server-only secrets — copy to .env.local (NEVER commit real keys; never reference VITE_* for these)
OPENAI_API_KEY=

# Optional: Supabase pgvector. If empty, the app falls back to an in-memory vector store.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Model selection (defaults shown)
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o
